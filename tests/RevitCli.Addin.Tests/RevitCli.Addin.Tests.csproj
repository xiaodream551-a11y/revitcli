<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RevitYear Condition="'$(RevitYear)' == ''">2026</RevitYear>
    <RevitInstallDir Condition="'$(RevitInstallDir)' == '' AND '$(Revit2026InstallDir)' != '' AND '$(RevitYear)' == '2026'">$(Revit2026InstallDir)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitInstallDir)' == '' AND '$(Revit2025InstallDir)' != '' AND '$(RevitYear)' == '2025'">$(Revit2025InstallDir)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitInstallDir)' == '' AND '$(Revit2024InstallDir)' != '' AND '$(RevitYear)' == '2024'">$(Revit2024InstallDir)</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitInstallDir)' == '' AND '$(RevitYear)' == '2024'">C:\Program Files\Autodesk\Revit 2024</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitInstallDir)' == '' AND '$(RevitYear)' == '2025'">C:\Program Files\Autodesk\Revit 2025</RevitInstallDir>
    <RevitInstallDir Condition="'$(RevitInstallDir)' == '' AND '$(RevitYear)' == '2026'">C:\Program Files\Autodesk\Revit 2026</RevitInstallDir>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="Moq" Version="4.20.72" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\RevitCli.Addin\RevitCli.Addin.csproj" />
    <ProjectReference Include="..\..\src\RevitCli\RevitCli.csproj" />
    <ProjectReference Include="..\..\shared\RevitCli.Shared\RevitCli.Shared.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="RevitAPI">
      <HintPath>$(RevitInstallDir)\RevitAPI.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>$(RevitInstallDir)\RevitAPIUI.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>
